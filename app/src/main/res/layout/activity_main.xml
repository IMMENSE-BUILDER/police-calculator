<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="8dp">

    <!-- Display Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="end|bottom"
        android:padding="24dp"
        android:background="@color/display_background"
        android:layout_marginBottom="8dp">

        <!-- Previous operation display -->
        <TextView
            android:id="@+id/previousOperation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="20sp"
            android:textColor="#80FFFFFF"
            android:gravity="end"
            android:singleLine="true"
            android:ellipsize="start" />

        <!-- Current number display -->
        <TextView
            android:id="@+id/currentNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="56sp"
            android:textColor="@color/white"
            android:gravity="end"
            android:singleLine="true"
            android:ellipsize="start"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Buttons Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:orientation="vertical"
        android:layout_marginTop="4dp">

        <!-- Row 1: C, ( ), %, ÷ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnClear"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/clear"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnParentheses"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/parentheses"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnPercent"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/percent"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnDivide"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/divide" />

        </LinearLayout>

        <!-- Row 2: 7, 8, 9, × -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btn7"
                style="@style/CalcButton.Number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/seven"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn8"
                style="@style/CalcButton.Number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/eight"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn9"
                style="@style/CalcButton.Number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/nine"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnMultiply"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/multiply" />

        </LinearLayout>

        <!-- Row 3: 4, 5, 6, - -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btn4"
                style="@style/CalcButton.Number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/four"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn5"
                style="@style/CalcButton.Number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/five"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn6"
                style="@style/CalcButton.Number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/six"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnSubtract"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/subtract" />

        </LinearLayout>

        <!-- Row 4: 1, 2, 3, + -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btn1"
                style="@style/CalcButton.Number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/one"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn2"
                style="@style/CalcButton.Number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/two"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn3"
                style="@style/CalcButton.Number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/three"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnAdd"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/add" />

        </LinearLayout>

        <!-- Row 5: +/-, 0, ., = -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnBackspace"
                style="@style/CalcButton.Function"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/delete"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn0"
                style="@style/CalcButton.Number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/zero"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnDecimal"
                style="@style/CalcButton.Number"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/decimal"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnEquals"
                style="@style/CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/equals" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
